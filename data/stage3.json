erTimeSec":1192,"courseLengthM":1960,"climbM":140}},"crops":[{"id":"hero","file":"crops/s3_hero_venla_L0.webp","memberId":"venla","legLabel":"S3→89","kind":"hero","ctrlFrom":"S3","ctrlTo":"89"},{"id":"villain","file":"crops/s3_villain_viivi_L7.webp","memberId":"viivi","legLabel":"96→151","kind":"villain","ctrlFrom":"96","ctrlTo":"151"},{"id":"duelHE","file":"crops/s3_duelHE_eevert_L15.webp","memberId":"eevert","legLabel":"125→134","kind":"duelHE","ctrlFrom":"125","ctrlTo":"134"},{"id":"duelCM","file":"crops/s3_duelCM_venla_L7.webp","memberId":"venla","legLabel":"142→140","kind":"duelCM","ctrlFrom":"142","ctrlTo":"140"}],"metsaradio":{"paragraphsFi":["Hyvät kuulijat — MÄKIKISA! Col de Chésery, rajanylitys, neljäsataa metriä pudotusta, ja Metsäradio huutaa itsensä käheäksi: VENLA TOIVONEN VOITTAA TAAS! Toinen etappivoitto, satakaksikymmentä lähtijää CM-sarjassa, Kultakontrolli ja yksitoista kärkiosuutta — ja serkkuduelissa puhdas kaksitoista–nolla Almaa vastaan. Yleiskilpailussa Venla johtaa ja Alma pitää pronssisijaa — kaksi lasta perheen kärkenä, ja ennustekone antaa molemmille lähes varman kärkikymmenyksen!","EEVERT TOIVONEN — mikä päivä! Viides sija HE-eliitissä, ja palkintopalli notkuu: Mäkikuningas KOLMATTA päivää putkeen, Tasatahti JA Raketti samaan kisaan. Kolmen mäkikruunun putki tuo Mäkikuningas ×3 -leiman kunniagalleriaan. Kaksintaistelussa Markukselle jää vain yksi osuus — 19–1. MARKUKSELLA rankka vuoristopäivä, mutta viikko on pitkä ja Sisu-mies tunnetaan nousuistaan.","VILHELM TOIVONEN ajaa viikon parhaan kisansa: yhdeksäs HAM-sarjassa, vain reilun minuutin moka, ja taas se maalisuora — 21 sekuntia! VIIVI nousee pidemmälle HL-radalle ja maksaa oppirahat rastilla 151 — melkein kymmenen minuuttia — mutta painaa silti perheen nopeimman maaliintulon, 19 sekuntia, ja ennuste lupaa kuutossijaa! SIRRA kahdestoista, MIKKO nappaa Sisu-palkinnon nousulla 34:nnestä 19:nneksi. Yleiskilpailu kolmen etapin jälkeen: Venla 1., Alma 3., Eevert 5., Sirra 7. Huomenna Portes du Soleil — aurinko nousee, ja niin nousee Toivosten kopla! Metsäradio kuittaa!"]},"overall":[{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":12972,"rankAfter":29,"of":56,"cumBehindSec":4755,"category":"HAM","memberId":"vilhelm"},{"rankable":false,"stagesCounted":[2,3],"cumTimeSec":3827,"rankAfter":null,"of":null,"cumBehindSec":null,"category":"HL","memberId":"viivi"},{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":11513,"rankAfter":7,"of":50,"cumBehindSec":3233,"category":"D45","memberId":"sirra"},{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":11460,"rankAfter":22,"of":78,"cumBehindSec":2723,"category":"H60","memberId":"mikko"},{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":5949,"rankAfter":3,"of":78,"cumBehindSec":779,"category":"CM","memberId":"alma"},{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":18101,"rankAfter":14,"of":35,"cumBehindSec":4906,"category":"HE","memberId":"markus"},{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":15616,"rankAfter":5,"of":35,"cumBehindSec":2421,"category":"HE","memberId":"eevert"},{"rankable":true,"stagesCounted":[1,2,3],"cumTimeSec":5170,"rankAfter":1,"of":78,"cumBehindSec":0,"category":"CM","memberId":"venla"}]}